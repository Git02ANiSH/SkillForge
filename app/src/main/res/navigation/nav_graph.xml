<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/onboardingFragment">

    <!-- Onboarding -->
    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.skillforge.app.features.onboarding.OnboardingFragment"
        android:label="Onboarding">

        <action
            android:id="@+id/action_onboardingFragment_to_loginFragment"
            app:destination="@id/loginFragment" />

    </fragment>

    <!-- Login -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.skillforge.app.features.auth.LoginFragment"
        android:label="Login">

        <action
            android:id="@+id/action_loginFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />

    </fragment>

    <!-- Dashboard -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.skillforge.app.features.dashboard.DashboardFragment"
        android:label="Dashboard">

        <action
            android:id="@+id/action_dashboardFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/dashboardFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_dashboardFragment_to_timetableFragment"
            app:destination="@id/timetableFragment" />

        <action
            android:id="@+id/action_dashboardFragment_to_attendanceFragment"
            app:destination="@id/attendanceFragment" />

        <action
            android:id="@+id/action_dashboardFragment_to_notesFragment"
            app:destination="@id/notesFragment" />

        <action
            android:id="@+id/action_dashboardFragment_to_aiMentorFragment"
            app:destination="@id/aiMentorFragment" />

    </fragment>

    <!-- Timetable -->
    <fragment
        android:id="@+id/timetableFragment"
        android:name="com.skillforge.app.features.timetable.TimetableFragment"
        android:label="Timetable" />

    <!-- Attendance -->
    <fragment
        android:id="@+id/attendanceFragment"
        android:name="com.skillforge.app.features.attendance.AttendanceFragment"
        android:label="Attendance" />
    <!-- Notes -->
    <fragment
        android:id="@+id/notesFragment"
        android:name="com.skillforge.app.features.notes.NotesFragment"
        android:label="Notes" />

    <!-- AI Mentor -->
    <fragment
        android:id="@+id/aiMentorFragment"
        android:name="com.skillforge.app.features.ai.AiMentorFragment"
        android:label="AI Mentor" />

</navigation>